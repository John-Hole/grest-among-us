{
  "rules": {
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "images": {
      "$roomId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["createdAt", "status"],
        "creatorId": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'finished')"
        },
        "currentRound": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "state": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren()",
          "round": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
          },
          "game_status": {
            ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'emergency' || newData.val() === 'discussion' || newData.val() === 'voting' || newData.val() === 'crewmates_win' || newData.val() === 'impostors_win'))"
          }
        },
        "players": {
          "$playerName": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['role', 'status'])",
            "name": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0 && newData.val().length <= 50)"
            },
            "role": {
              ".validate": "newData.isString() && (newData.val() === 'crewmate' || newData.val() === 'impostor' || newData.val() === 'scientist')"
            },
            "status": {
              ".validate": "newData.isString() && (newData.val() === 'alive' || newData.val() === 'killed_hidden' || newData.val() === 'killed_revealed' || newData.val() === 'dead' || newData.val() === 'ghost')"
            },
            "joinedAt": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "lastSeen": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "tasks": {
              "$taskId": {
                ".write": "auth != null",
                "completed": {
                  ".validate": "newData.isBoolean()"
                },
                "completedAt": {
                  ".validate": "newData.isNumber() && newData.val() <= now"
                }
              }
            },
            "kills": {
              "$killId": {
                ".write": "auth != null",
                "targetId": {
                  ".validate": "newData.isString()"
                },
                "timestamp": {
                  ".validate": "newData.isNumber() && newData.val() <= now"
                }
              }
            }
          }
        },
        "votes": {
          ".read": "auth != null",
          "$playerName": {
            ".write": "auth != null"
          }
        },
        "config": {
          ".read": "auth != null",
          ".write": "auth != null && (root.child('rooms').child($roomId).child('creatorId').val() === auth.uid || (root.child('rooms').child($roomId).child('createdAt').exists() && root.child('rooms').child($roomId).child('createdAt').val() < now - 86400000))",
          "roundTimes": {
            ".validate": "newData.hasChildren()"
          },
          "discussionTime": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "votingTime": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          }
        }
      }
    },
    "rateLimit": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.hasChildren()",
        "lastRoomCreation": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "publicMetadata": {
      ".read": true,
      ".write": false,
      "version": {
        ".validate": "newData.isString()"
      },
      "maintenance": {
        ".validate": "newData.isBoolean()"
      }
    },
    ".read": false,
    ".write": false
  }
}
